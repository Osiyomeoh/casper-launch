# ── Casper Agent Keys ─────────────────────────────────────────────────────────
AGENT_SECRET_KEY_PEM=          # ED25519 private key PEM for autonomous agent transactions
NEXT_PUBLIC_AGENT_PUBLIC_KEY=  # Corresponding public key (hex, 01..., 66 chars)

# ── Casper Contract Hashes (testnet) ──────────────────────────────────────────
NEXT_PUBLIC_RWA_NFT_HASH=      # CEP-78 RWA NFT contract hash (64 hex chars, no "hash-" prefix)
NEXT_PUBLIC_YIELD_HASH=        # Yield distributor contract hash
NEXT_PUBLIC_ESCROW_HASH=       # Trade escrow contract hash
NEXT_PUBLIC_GOV_HASH=          # Governance contract hash

# ── AI / LLM ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=                  # Groq API key — get one at console.groq.com

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=                  # Neon Postgres connection string (postgresql://...)

# ── CSPR.cloud ────────────────────────────────────────────────────────────────
CSPR_CLOUD_API_KEY=            # CSPR.cloud API key — get one at console.cspr.cloud

# ── IPFS / Pinata ─────────────────────────────────────────────────────────────
PINATA_JWT=                    # Pinata JWT for IPFS document uploads
NEXT_PUBLIC_GATEWAY_URL=       # Pinata gateway URL (e.g. https://gateway.pinata.cloud)
